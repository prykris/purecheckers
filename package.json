{
  "name": "checkers",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite dev",
    "dev:server": "nodemon server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npx prisma generate && vite build",
    "start": "npx prisma db push && NODE_ENV=production node server/index.js",
    "deploy": "npm run build && npx prisma db push && npm run db:seed",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "svelte": "^5.55.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  }
}
